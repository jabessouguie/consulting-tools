"""
Tests unitaires pour document_parser
"""

import os
import sys
import tempfile
from pathlib import Path

import pytest

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from utils.document_parser import extract_text_from_file, parse_docx, parse_pdf, parse_txt


class TestParsePdf:
    """Tests pour parse_pdf"""

    def test_parse_valid_pdf(self):
        """Test parsing d'un PDF valide"""
        # Créer un PDF de test
        with tempfile.NamedTemporaryFile(suffix=".pdf", delete=False) as f:
            # Note: Dans un test réel, utiliseriez PyPDF2 pour créer un vrai PDF
            pdf_path = f.name

        try:
            # Mock du parsing PDF
            with pytest.raises(Exception):
                # Le fichier temporaire n'est pas un vrai PDF
                result = parse_pdf(pdf_path)
        finally:
            os.unlink(pdf_path)

    def test_parse_nonexistent_pdf(self):
        """Test parsing PDF inexistant"""
        with pytest.raises(FileNotFoundError):
            parse_pdf("/nonexistent/file.pdf")

    def test_parse_invalid_pdf(self):
        """Test parsing fichier non-PDF"""
        with tempfile.NamedTemporaryFile(suffix=".txt", delete=False) as f:
            f.write(b"Not a PDF")
            txt_path = f.name

        try:
            with pytest.raises(Exception):
                parse_pdf(txt_path)
        finally:
            os.unlink(txt_path)


