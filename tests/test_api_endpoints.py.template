class TestRateLimiting:
    """Tests pour le rate limiting"""

    def test_rate_limit_enforced(self):
        """Test que le rate limiting est appliqué"""
        # Faire beaucoup de requêtes rapidement
        responses = []
        for _ in range(100):
            response = client.get("/health")
            responses.append(response.status_code)

        # Au moins une requête devrait être limitée (429)
        assert 429 in responses or all(code == 200 for code in responses)


class TestErrorHandling:
    """Tests pour la gestion des erreurs"""

    def test_404_on_unknown_endpoint(self):
        """Test 404 sur endpoint inconnu"""
        response = client.get("/nonexistent-endpoint")
        assert response.status_code == 404

    def test_405_on_wrong_method(self):
        """Test 405 sur méthode HTTP incorrecte"""
        response = client.post("/")  # GET endpoint appelé en POST
        assert response.status_code == 405


