"""
Tests d'intégration pour les endpoints API FastAPI
"""

import os
import sys
from unittest.mock import MagicMock, patch

import pytest
from fastapi.testclient import TestClient

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

# Mock environment variables before importing app
with patch.dict(
    os.environ,
    {
        "ANTHROPIC_API_KEY": "test-key",
        "CONSULTANT_NAME": "Test Consultant",
        "COMPANY_NAME": "Test Company",
    },
):
    from app import app

client = TestClient(app)


class TestRootEndpoints:
    """Tests pour les endpoints racine"""

    def test_root_endpoint(self):
        """Test endpoint racine /"""
        response = client.get("/")
        assert response.status_code == 200
        assert "text/html" in response.headers["content-type"]

    def test_health_check(self):
        """Test endpoint health check"""
        response = client.get("/health")
        assert response.status_code == 200
        data = response.json()
        assert data["status"] == "healthy"


class TestSlideEditorEndpoints:
    """Tests pour les endpoints slide-editor"""

    def test_slide_editor_page(self):
        """Test page slide editor"""
        response = client.get("/slide-editor")
        assert response.status_code == 200
        assert "Slide Editor" in response.text

    @patch("agents.training_slides_generator.TrainingSlidesGenerator")
    def test_start_slide_generation(self, mock_generator):
        """Test démarrage génération de slides"""
        response = client.post(
            "/api/slide-editor/start-generate",
            data={
                "topic": "Python Programming",
                "audience": "Developers",
                "slide_count": "10",
                "generation_type": "presentation",
            },
        )

        assert response.status_code == 200
        data = response.json()
        assert "job_id" in data

    def test_start_slide_generation_missing_topic(self):
        """Test génération sans topic (erreur)"""
        response = client.post(
            "/api/slide-editor/start-generate", data={"audience": "Developers", "slide_count": "10"}
        )

        assert response.status_code == 422  # Validation error


