"""
Tests unitaires pour google_api
"""

import os
import sys
from unittest.mock import MagicMock, Mock, patch

import pytest

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from utils.google_api import GoogleAPIClient


class TestGoogleAPIClient:
    """Tests pour GoogleAPIClient"""

    @patch("utils.google_api.os.path.exists")
    def test_init_without_credentials(self, mock_exists):
        """Test initialisation sans credentials"""
        mock_exists.return_value = False

        with pytest.raises(FileNotFoundError):
            GoogleAPIClient(credentials_path="nonexistent.json")

    @patch("utils.google_api.service_account.Credentials.from_service_account_file")
    @patch("utils.google_api.os.path.exists")
    def test_init_with_service_account(self, mock_exists, mock_creds):
        """Test initialisation avec service account"""
        mock_exists.return_value = True
        mock_creds.return_value = MagicMock()

        client = GoogleAPIClient(credentials_path="test.json")
        assert client is not None

    @patch("utils.google_api.build")
    @patch("utils.google_api.service_account.Credentials.from_service_account_file")
    @patch("utils.google_api.os.path.exists")
    def test_build_service_slides(self, mock_exists, mock_creds, mock_build):
        """Test construction service Google Slides"""
        mock_exists.return_value = True
        mock_creds.return_value = MagicMock()
        mock_service = MagicMock()
        mock_build.return_value = mock_service

        client = GoogleAPIClient(credentials_path="test.json")
        service = client._build_service("slides", "v1")

        assert service == mock_service
        mock_build.assert_called_with("slides", "v1", credentials=mock_creds.return_value)

    @patch("utils.google_api.build")
    @patch("utils.google_api.service_account.Credentials.from_service_account_file")
    @patch("utils.google_api.os.path.exists")
    def test_build_service_docs(self, mock_exists, mock_creds, mock_build):
        """Test construction service Google Docs"""
        mock_exists.return_value = True
        mock_creds.return_value = MagicMock()
        mock_service = MagicMock()
        mock_build.return_value = mock_service

        client = GoogleAPIClient(credentials_path="test.json")
        service = client._build_service("docs", "v1")

        mock_build.assert_called_with("docs", "v1", credentials=mock_creds.return_value)

    @patch("utils.google_api.build")
    @patch("utils.google_api.service_account.Credentials.from_service_account_file")
    @patch("utils.google_api.os.path.exists")
    def test_create_presentation(self, mock_exists, mock_creds, mock_build):
        """Test création d'une présentation"""
        mock_exists.return_value = True
        mock_creds.return_value = MagicMock()

        mock_service = MagicMock()
        mock_presentations = MagicMock()
        mock_create = MagicMock()
        mock_execute = MagicMock(
            return_value={"presentationId": "test-123", "title": "Test Presentation"}
        )

        mock_create.execute = mock_execute
        mock_presentations.create.return_value = mock_create
        mock_service.presentations.return_value = mock_presentations
        mock_build.return_value = mock_service

        client = GoogleAPIClient(credentials_path="test.json")
        result = client.create_presentation(title="Test Presentation")

        assert result["presentationId"] == "test-123"
        assert result["title"] == "Test Presentation"

    @patch("utils.google_api.service_account.Credentials.from_service_account_file")
    @patch("utils.google_api.os.path.exists")
    def test_get_presentation_url(self, mock_exists, mock_creds):
        """Test génération URL présentation"""
        mock_exists.return_value = True
        mock_creds.return_value = MagicMock()

        client = GoogleAPIClient(credentials_path="test.json")
        url = client.get_presentation_url("test-presentation-id")

        assert "test-presentation-id" in url
        assert "https://docs.google.com/presentation" in url

    @patch("utils.google_api.service_account.Credentials.from_service_account_file")
    @patch("utils.google_api.os.path.exists")
    def test_get_document_url(self, mock_exists, mock_creds):
        """Test génération URL document"""
        mock_exists.return_value = True
        mock_creds.return_value = MagicMock()

        client = GoogleAPIClient(credentials_path="test.json")
        url = client.get_document_url("test-doc-id")

        assert "test-doc-id" in url
        assert "https://docs.google.com/document" in url
